# --- Supabase ---
# From Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# From Supabase project Settings > Database > Connection string (use the "Transaction" pooler URI for DATABASE_URL,
# and the direct connection URI for DIRECT_URL, which Prisma needs for migrations)
DATABASE_URL=
DIRECT_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (transactional email, wired in Phase 5) ---
RESEND_API_KEY=

# --- Worldline Saferpay (payments, wired in Phase 4) ---
SAFERPAY_CUSTOMER_ID=
SAFERPAY_TERMINAL_ID=
SAFERPAY_API_USERNAME=
SAFERPAY_API_PASSWORD=
